# ── Server ─────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGIN=

# ── Database (MySQL) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=redrose_db

# ── Auth (Clerk) ───────────────────────────────────────
# The backend verifies Clerk session JWTs via the issuer's JWKS — no secret
# needed here for verification. Set AUTH_DISABLED=true ONLY for local dev to
# bypass auth on protected endpoints.
AUTH_DISABLED=false

# ── Email (Resend) ─────────────────────────────────────
# Leave RESEND_API_KEY empty to disable email notifications.
RESEND_API_KEY=
FROM_EMAIL=RedRose <onboarding@resend.dev>
ADMIN_EMAIL=
ADMIN_URL=http://localhost:3001
